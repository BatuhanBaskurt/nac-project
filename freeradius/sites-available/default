server default {
    listen {
        type = auth
        ipaddr = *
        port = 1812
    }

    listen {
        type = acct
        ipaddr = *
        port = 1813
    }

    authorize {
        rest
        if (ok || updated) {
            update control {
                Auth-Type := Accept
            }
        }
    }

    authenticate {
        Auth-Type PAP {
            pap
        }
    }

    accounting {
        rest
    }
}
